# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME="LearnOS AI"
DEBUG=false
ENVIRONMENT=production
SECRET_KEY=your-super-secret-key-min-32-chars-change-this

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://learnos.ai"]

# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase: Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# ─── Redis ────────────────────────────────────────────────────────────────────
# Upstash Redis or Railway Redis
REDIS_URL=redis://localhost:6379/0

# ─── Clerk Auth ───────────────────────────────────────────────────────────────
# https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
CLERK_JWT_ISSUER=https://your-clerk-domain.clerk.accounts.dev

# ─── AI Models ────────────────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# https://aistudio.google.com/
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxx

# ─── Search APIs ──────────────────────────────────────────────────────────────
# https://app.tavily.com/
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx
# https://exa.ai/
EXA_API_KEY=xxxxxxxxxxxxxxxxxxxx
# https://www.firecrawl.dev/
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxx
# https://console.cloud.google.com/ → YouTube Data API v3
YOUTUBE_API_KEY=AIzaxxxxxxxxxxxxxxxx

# ─── Vector DB ────────────────────────────────────────────────────────────────
# https://app.pinecone.io/
PINECONE_API_KEY=xxxxxxxxxxxxxxxxxxxx
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX=learnos-resources

# ─── AWS S3 (optional for file uploads) ──────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
AWS_BUCKET_NAME=learnos-storage
AWS_REGION=us-east-1

# ─── Monitoring ───────────────────────────────────────────────────────────────
# https://sentry.io/
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
